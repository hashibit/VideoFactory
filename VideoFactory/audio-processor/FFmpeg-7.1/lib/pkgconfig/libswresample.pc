prefix=/opt/homebrew/Cellar/ffmpeg/7.1_3
exec_prefix=${prefix}
libdir=/opt/homebrew/Cellar/ffmpeg/7.1_3/lib
includedir=/opt/homebrew/Cellar/ffmpeg/7.1_3/include

Name: libswresample
Description: FFmpeg audio resampling library
Version: 5.3.100
Requires: 
Requires.private: libavutil >= 59.39.100
Conflicts:
Libs: -L${libdir}  -lswresample 
Libs.private: -lm -lsoxr
Cflags: -I${includedir}
